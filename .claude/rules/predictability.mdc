## B. 같은 종류의 함수는 반환 타입 통일하기

같은 종류의 함수/Hook이 서로 다른 반환 타입을 가지면 일관성이 떨어지고 버그가 발생한다.

```typescript
// Bad - useUser는 Query 객체, useServerTime은 data만 반환
function useUser() { return useQuery({ ... }); }          // Query 객체
function useServerTime() { return useQuery({ ... }).data; } // data만

// Good - 같은 종류는 같은 타입 반환
function useUser() { return useQuery({ ... }); }       // Query 객체
function useServerTime() { return useQuery({ ... }); } // Query 객체
```

### 유효성 검사 함수의 반환 타입 통일

```typescript
// Bad - boolean과 객체가 섞임
function checkIsNameValid(name: string) { return name.length > 0; }         // boolean
function checkIsAgeValid(age: number) { return { ok: true }; }              // 객체 → if(checkIsAgeValid(age))는 항상 truthy!

// Good - Discriminated Union으로 통일
type ValidationResult = { ok: true } | { ok: false; reason: string };

function checkIsNameValid(name: string): ValidationResult {
  if (name.length === 0) return { ok: false, reason: "이름을 입력해주세요." };
  return { ok: true };
}
function checkIsAgeValid(age: number): ValidationResult {
  if (age < 18) return { ok: false, reason: "나이는 18세 이상이어야 해요." };
  return { ok: true };
}
```

